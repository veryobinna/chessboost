# Copy to .env and fill in.

# Local dev: use the bundled docker-compose Postgres (both URLs identical).
#   DATABASE_URL="postgresql://chessboost:chessboost@localhost:5433/chessboost?schema=public"
#   DIRECT_URL="postgresql://chessboost:chessboost@localhost:5433/chessboost?schema=public"
#
# Production (Neon): pooled URL for runtime, direct URL for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Random secret used to sign the guest-session cookie (e.g. `openssl rand -base64 32`).
GUEST_SECRET="change-me"
