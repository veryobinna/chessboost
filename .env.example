# Copy to .env and fill in.

# Local dev: use the bundled docker-compose Postgres.
#   DATABASE_URL="postgresql://chessboost:chessboost@localhost:5433/chessboost?schema=public"
# Production: a Neon (or other) Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Random secret used to sign the guest-session cookie (e.g. `openssl rand -base64 32`).
GUEST_SECRET="change-me"
